generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  createdAt  DateTime  @default(now()) @map("created_at")
  modifiedAt DateTime  @updatedAt @map("modified_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("users")
}
